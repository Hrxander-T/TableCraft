{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TableCraft",
  "version": "0.1.0",
  "identifier": "com.tablecraft.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TableCraft",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main window permissions",
          "windows": ["main"],
          "permissions": [
            "dialog:default",
            "dialog:allow-save",
            "dialog:allow-open",
            "fs:default",
            "fs:allow-write-text-file",
            "fs:allow-read-text-file",
            "fs:allow-write-file"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
